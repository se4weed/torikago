<div class="address-demo">
  <header class="page-header">
    <p class="eyebrow">torikago module-local gem demo</p>
    <h1>Postal Code Lookup</h1>
    <p class="lede">foo and bar load different jpostcode snapshots, then look up the same postal code inside separate Boxes.</p>
  </header>

  <section class="panel search-panel">
    <div class="panel-body">
      <%= form_with local: true, method: :post, url: search_addresses_path do |f| %>
        <div class="form-row">
          <%= f.label :postal_code, "Postal Code" %>
          <%= f.text_field :postal_code, value: @lookup.postal_code, placeholder: "e.g., 013-0310", class: "form-control" %>
          <%= f.submit "Search", class: "btn" %>
        </div>
        <small class="hint">Format: XXX-XXXX, e.g. 013-0310</small>
      <% end %>
    </div>
  </section>

  <% if @lookup.searched? %>
    <div class="result-grid">
      <section class="panel result-panel">
        <div class="panel-header">
          <div>
            <p class="module-name">foo module</p>
            <h2>jpostcode v1.0.0.20250901</h2>
          </div>
          <span class="badge badge-foo">old dataset</span>
        </div>
        <div class="panel-body">
          <% if @lookup.foo_result&.dig("success") %>
            <dl class="facts">
              <dt>Module</dt>
              <dd><%= @lookup.foo_result["module"] %></dd>
              <dt>Gem Version</dt>
              <dd><%= @lookup.foo_result["gem_version"] %></dd>
              <dt>Postal Code</dt>
              <dd><%= @lookup.foo_result["postal_code"] %></dd>
            </dl>
            <div class="address-result success"><%= @lookup.foo_result["address"] %></div>
          <% else %>
            <div class="address-result missing"><%= @lookup.foo_result&.dig("message") %></div>
          <% end %>
        </div>
      </section>

      <section class="panel result-panel">
        <div class="panel-header">
          <div>
            <p class="module-name">bar module</p>
            <h2>jpostcode v1.0.0.20260507</h2>
          </div>
          <span class="badge badge-bar">new dataset</span>
        </div>
        <div class="panel-body">
          <% if @lookup.bar_result&.dig("success") %>
            <dl class="facts">
              <dt>Module</dt>
              <dd><%= @lookup.bar_result["module"] %></dd>
              <dt>Gem Version</dt>
              <dd><%= @lookup.bar_result["gem_version"] %></dd>
              <dt>Postal Code</dt>
              <dd><%= @lookup.bar_result["postal_code"] %></dd>
            </dl>
            <div class="address-result success"><%= @lookup.bar_result["address"] %></div>
          <% else %>
            <div class="address-result missing"><%= @lookup.bar_result&.dig("message") %></div>
          <% end %>
        </div>
      </section>
    </div>

    <section class="panel comparison-panel">
      <div class="panel-header">
        <h2>Comparison</h2>
      </div>
      <div class="panel-body comparison-body">
        <p>
          <strong>Lookup:</strong>
          <code>Jpostcode.find("<%= @lookup.postal_code %>")</code>
        </p>
        <% if @lookup.foo_result["address"] && @lookup.bar_result["address"] %>
          <p>
            <strong>Addresses Match:</strong>
            <span class="status <%= @lookup.addresses_match? ? 'status-success' : 'status-warning' %>">
              <%= @lookup.addresses_match? ? 'Yes' : 'Different' %>
            </span>
          </p>
        <% end %>
        <p>
          <strong>Gem Versions Match:</strong>
          <span class="status <%= @lookup.versions_match? ? 'status-danger' : 'status-success' %>">
            <%= @lookup.versions_match? ? 'Yes' : 'No (as expected)' %>
          </span>
        </p>
      </div>
    </section>
  <% end %>
</div>

<style>
  .address-demo {
    max-width: 1000px;
    margin: 0 auto;
    padding: 32px 20px;
    color: #172033;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .page-header {
    margin-bottom: 24px;
  }

  .eyebrow {
    margin: 0 0 8px;
    color: #52647a;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .address-demo h1 {
    margin: 0 0 8px;
    font-size: 2rem;
    letter-spacing: 0;
  }

  .lede {
    margin: 0;
    color: #43546a;
  }

  .panel {
    border: 1px solid #d7dee8;
    border-radius: 8px;
    background: #fff;
  }

  .search-panel,
  .comparison-panel {
    margin-bottom: 20px;
  }

  .panel-header,
  .panel-body {
    padding: 18px;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid #e5eaf1;
  }

  .panel-header h2 {
    margin: 0;
    font-size: 1rem;
    letter-spacing: 0;
  }

  .module-name {
    margin: 0 0 4px;
    color: #64748b;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .form-row {
    display: flex;
    align-items: end;
    gap: 10px;
    flex-wrap: wrap;
  }

  .form-row label {
    flex-basis: 100%;
    font-weight: 700;
  }

  .form-control {
    width: min(100%, 220px);
    height: 36px;
    padding: 6px 10px;
    border: 1px solid #aeb8c6;
    border-radius: 6px;
    font: inherit;
  }

  .btn {
    height: 36px;
    padding: 0 14px;
    border: 1px solid #1f4f8f;
    border-radius: 6px;
    background: #255fa8;
    color: #fff;
    font: inherit;
    font-weight: 700;
  }

  .hint {
    display: block;
    margin-top: 8px;
    color: #64748b;
  }

  .result-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-bottom: 20px;
  }

  .badge,
  .status {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .badge-foo {
    background: #e9f3ff;
    color: #18528c;
  }

  .badge-bar {
    background: #fff3d6;
    color: #765111;
  }

  .facts {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 12px;
    margin: 0 0 16px;
  }

  .facts dt {
    color: #64748b;
    font-weight: 700;
  }

  .facts dd {
    margin: 0;
  }

  .address-result {
    padding: 12px;
    border-radius: 8px;
    line-height: 1.7;
  }

  .address-result.success {
    border: 1px solid #b7e2c1;
    background: #eefaf1;
    color: #164b26;
  }

  .address-result.missing {
    border: 1px solid #f2c3c3;
    background: #fff1f1;
    color: #7f1d1d;
  }

  .comparison-body p {
    margin: 0 0 12px;
  }

  .comparison-body p:last-child {
    margin-bottom: 0;
  }

  .status-success {
    background: #e8f8ee;
    color: #17613a;
  }

  .status-warning {
    background: #fff7d8;
    color: #755113;
  }

  .status-danger {
    background: #ffe8e8;
    color: #8a1f1f;
  }

  @media (max-width: 760px) {
    .result-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
