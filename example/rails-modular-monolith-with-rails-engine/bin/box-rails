#!/usr/bin/env ruby
require "rbconfig"

app_root = File.expand_path("..", __dir__)

# Temporary runner until Ruby bug #22123 is fixed:
# https://bugs.ruby-lang.org/issues/22123
# Ruby::Box + BUNDLER_SETUP can evaluate gemspecs before main-box RubyGems
# initialization, so avoid inherited Bundler setup env when starting Rails.
ENV["BUNDLE_GEMFILE"] = File.join(app_root, "Gemfile")
ENV["RUBY_BOX"] = "1"

if ENV["RUBYOPT"]&.include?("bundler/setup")
  rubyopt = ENV["RUBYOPT"].split.reject { |option| option.include?("bundler/setup") }
  rubyopt.empty? ? ENV.delete("RUBYOPT") : ENV["RUBYOPT"] = rubyopt.join(" ")
end

ENV.delete("BUNDLER_SETUP")

exec RbConfig.ruby, File.join(__dir__, "rails"), *ARGV
